# ============================================
# API GATEWAY — PROXY CONFIGURATION
# ============================================
# Copy to .env.local and configure with your values

# Gateway Identification
GATEWAY_ID=victor-ia-app-prod

# Backend URLs (external services)
# If not set, defaults to public APIs
STRIPE_API_BACKEND=https://api.stripe.com/v1
SUPABASE_BACKEND=https://[your-project].supabase.co/rest/v1
OPENAI_API_BACKEND=https://api.openai.com/v1
MAIL_API_BACKEND=https://api.mailgun.net/v3

# Optional: IP Whitelist (comma-separated)
# Leave empty to accept all IPs
# Example: 192.168.1.100,10.0.0.0/8,203.0.113.50
GATEWAY_IP_WHITELIST=

# Rate Limiting (requests per minute, per user)
# These are used in the route handler
STRIPE_RATE_LIMIT=100
SUPABASE_RATE_LIMIT=1000
OPENAI_RATE_LIMIT=500
MAIL_RATE_LIMIT=50

# Audit Logging
# Send audit logs to webhook URL for sensitive operations
AUDIT_LOG_WEBHOOK=
AUDIT_LOG_ENABLED=true

# CORS Configuration
GATEWAY_CORS_ORIGINS=https://victor-ia-app.vercel.app,http://localhost:3000

# TLS/mTLS (if backend requires mutual authentication)
# GATEWAY_TLS_CERT_PATH=/etc/certs/gateway.crt
# GATEWAY_TLS_KEY_PATH=/etc/certs/gateway.key
