import { NextResponse, type NextRequest } from 'next/server';
import { getAuth } from '@clerk/nextjs/server';

/**
 * API Gateway Pattern — Proxy Route
 * Intercepts requests to external services, validates authorization,
 * rewrites URLs, and masks infrastructure details.
 *
 * Supported backends:
 * - /api/proxy/stripe/* → Stripe API
 * - /api/proxy/data/* → Supabase REST API
 * - /api/proxy/ai/* → OpenAI/Anthropic APIs
 * - /api/proxy/mail/* → Email service
 *
 * Security features:
 * - Bearer token validation (Clerk JWT or API key)
 * - IP whitelist enforcement (optional)
 * - URL rewriting (hides actual backend URLs)
 * - Request/response header sanitization
 * - Rate limiting per user
 * - Audit logging for sensitive operations
 */

// Mapping of proxy paths to actual backend URLs
const BACKEND_ROUTES: Record<string, string> = {
  stripe: process.env.STRIPE_API_BACKEND || 'https://api.stripe.com/v1',
  data: process.env.SUPABASE_BACKEND || `${process.env.NEXT_PUBLIC_SUPABASE_URL}/rest/v1`,
  ai: process.env.OPENAI_API_BACKEND || 'https://api.openai.com/v1',
  mail: process.env.MAIL_API_BACKEND || 'https://api.mailgun.net/v3',
};

// Headers that should never be forwarded to the client
const SENSITIVE_RESPONSE_HEADERS = [
  'x-powered-by',
  'server',
  'x-aspnet-version',
  'x-runtime-version',
  'x-backend-server',
  'x-internal-id',
  'x-gateway-route',
  'x-real-ip',
  'x-forwarded-for',
];

// Endpoints that require additional validation
const SENSITIVE_ENDPOINTS = [
  /^stripe\/customers\/.+\/delete/,
  /^stripe\/charges\/.+\/refund/,
  /^data\/users\/.+/,
  /^ai\/models\/.+\/(delete|update)/,
];

interface ProxyRequest {
  path: string;
  service: string;
  endpoint: string;
  userId?: string;
  method: string;
}

interface ProxyConfig {
  requireAuth: boolean;
  requireAdmin?: boolean;
  rateLimitPerMinute: number;
  auditLog: boolean;
}

// Configuration per service
const SERVICE_CONFIG: Record<string, ProxyConfig> = {
  stripe: {
    requireAuth: true,
    rateLimitPerMinute: 100,
    auditLog: true,
  },
  data: {
    requireAuth: true,
    rateLimitPerMinute: 1000,
    auditLog: false,
  },
  ai: {
    requireAuth: true,
    rateLimitPerMinute: 500,
    auditLog: false,
  },
  mail: {
    requireAuth: true,
    rateLimitPerMinute: 50,
    auditLog: true,
  },
};

/**
 * Extract service and endpoint from proxy path
 * Example: ["stripe", "customers", "cus_123"] → { service: "stripe", endpoint: "customers/cus_123" }
 */
function parseProxyPath(pathParts: string[]): ProxyRequest {
  if (!pathParts || pathParts.length < 1) {
    throw new Error('Invalid proxy path');
  }

  const service = pathParts[0];
  const endpoint = pathParts.slice(1).join('/');

  return {
    path: pathParts.join('/'),
    service,
    endpoint,
    method: 'GET',
  };
}

/**
 * Validate authorization based on service and endpoint
 */
async function validateAuth(req: NextRequest, service: string): Promise<string | null> {
  try {
    const auth = await getAuth(req);

    if (!auth.userId) {
      const apiKey = req.headers.get('Authorization')?.replace('Bearer ', '');
      if (!apiKey) return null;

      // Validate API key (implement based on your API key storage)
      // For now, we'll require Clerk authentication
      return null;
    }

    return auth.userId;
  } catch (error) {
    console.error('Auth validation error:', error);
    return null;
  }
}

/**
 * Check IP whitelist (if configured)
 */
function validateIPWhitelist(req: NextRequest): boolean {
  const whitelist = process.env.GATEWAY_IP_WHITELIST?.split(',') || [];
  if (whitelist.length === 0) return true; // No whitelist configured

  const clientIP = req.headers.get('x-forwarded-for')?.split(',')[0].trim() ||
    req.headers.get('x-real-ip') ||
    req.ip ||
    '';

  return whitelist.includes(clientIP);
}

/**
 * Rate limiting check (simple in-memory, use Redis in production)
 */
const rateLimitStore = new Map<string, { count: number; resetTime: number }>();

function checkRateLimit(userId: string, service: string, limit: number): boolean {
  const key = `${userId}:${service}`;
  const now = Date.now();
  const entry = rateLimitStore.get(key);

  if (!entry || entry.resetTime < now) {
    rateLimitStore.set(key, { count: 1, resetTime: now + 60000 });
    return true;
  }

  if (entry.count >= limit) {
    return false;
  }

  entry.count++;
  return true;
}

/**
 * Clean sensitive response headers
 */
function sanitizeResponseHeaders(headers: Headers): Headers {
  const sanitized = new Headers(headers);

  SENSITIVE_RESPONSE_HEADERS.forEach((header) => {
    sanitized.delete(header);
  });

  // Add security headers
  sanitized.set('X-Content-Type-Options', 'nosniff');
  sanitized.set('X-Frame-Options', 'DENY');
  sanitized.set('X-XSS-Protection', '1; mode=block');

  return sanitized;
}

/**
 * Forward request to backend with proper headers
 */
async function forwardToBackend(
  service: string,
  endpoint: string,
  req: NextRequest,
  userId: string
): Promise<Response> {
  const backendUrl = BACKEND_ROUTES[service];
  if (!backendUrl) {
    throw new Error(`Unknown service: ${service}`);
  }

  const targetUrl = new URL(`${backendUrl}/${endpoint}`);

  // Preserve query parameters
  req.nextUrl.searchParams.forEach((value, key) => {
    targetUrl.searchParams.append(key, value);
  });

  // Build headers for backend
  const headers = new Headers();

  // Copy relevant request headers
  const relevantHeaders = [
    'content-type',
    'accept',
    'accept-encoding',
    'content-length',
    'authorization',
  ];

  relevantHeaders.forEach((header) => {
    const value = req.headers.get(header);
    if (value) {
      headers.set(header, value);
    }
  });

  // Add internal headers for backend identification
  headers.set('X-Gateway-ID', process.env.GATEWAY_ID || 'victor-ia-app');
  headers.set('X-User-ID', userId);
  headers.set('X-Forwarded-By', 'API Gateway');

  // Don't forward the Authorization header from client; use backend-specific auth
  headers.delete('Authorization');

  // Add service-specific authentication
  switch (service) {
    case 'stripe':
      if (process.env.STRIPE_SECRET_KEY) {
        const auth = Buffer.from(`${process.env.STRIPE_SECRET_KEY}:`).toString('base64');
        headers.set('Authorization', `Basic ${auth}`);
      }
      break;

    case 'data':
      if (process.env.SUPABASE_SERVICE_ROLE_KEY) {
        headers.set('Authorization', `Bearer ${process.env.SUPABASE_SERVICE_ROLE_KEY}`);
      }
      break;

    case 'ai':
      if (process.env.ANTHROPIC_API_KEY) {
        headers.set('x-api-key', process.env.ANTHROPIC_API_KEY);
      }
      break;

    case 'mail':
      if (process.env.MAILGUN_API_KEY) {
        const auth = Buffer.from(`api:${process.env.MAILGUN_API_KEY}`).toString('base64');
        headers.set('Authorization', `Basic ${auth}`);
      }
      break;
  }

  // Forward the request
  const body = ['GET', 'HEAD'].includes(req.method) ? undefined : await req.text();

  const response = await fetch(targetUrl.toString(), {
    method: req.method,
    headers,
    body,
    ...(process.env.NODE_ENV === 'development' && { timeout: 30000 }),
  });

  return response;
}

/**
 * Audit log sensitive operations
 */
async function auditLog(
  userId: string,
  service: string,
  endpoint: string,
  method: string,
  statusCode: number,
  isSensitive: boolean
): Promise<void> {
  if (!isSensitive) return;

  const logEntry = {
    timestamp: new Date().toISOString(),
    userId,
    service,
    endpoint,
    method,
    statusCode,
    gatewayId: process.env.GATEWAY_ID,
  };

  console.log('AUDIT_LOG:', JSON.stringify(logEntry));

  // TODO: Send to audit service (e.g., webhook, database)
  // await sendToAuditService(logEntry);
}

/**
 * Check if endpoint is sensitive
 */
function isSensitiveOperation(service: string, endpoint: string, method: string): boolean {
  if (method !== 'POST' && method !== 'DELETE' && method !== 'PUT') {
    return false;
  }

  const fullPath = `${service}/${endpoint}`;
  return SENSITIVE_ENDPOINTS.some((regex) => regex.test(fullPath));
}

/**
 * Main handler
 */
export async function middleware(
  req: NextRequest,
  { params }: { params: { path: string[] } }
) {
  try {
    // Parse the proxy path
    const proxyReq = parseProxyPath(params.path);

    // Get service configuration
    const config = SERVICE_CONFIG[proxyReq.service];
    if (!config) {
      return NextResponse.json(
        { error: 'Service not found', message: `Service "${proxyReq.service}" is not available` },
        { status: 404 }
      );
    }

    // Validate IP whitelist
    if (!validateIPWhitelist(req)) {
      return NextResponse.json(
        { error: 'Forbidden', message: 'IP address not whitelisted' },
        { status: 403 }
      );
    }

    // Validate authentication
    if (config.requireAuth) {
      const userId = await validateAuth(req, proxyReq.service);
      if (!userId) {
        return NextResponse.json(
          { error: 'Unauthorized', message: 'Valid authentication required' },
          { status: 401 }
        );
      }
      proxyReq.userId = userId;
    }

    // Check rate limiting
    if (proxyReq.userId) {
      const allowed = checkRateLimit(
        proxyReq.userId,
        proxyReq.service,
        config.rateLimitPerMinute
      );

      if (!allowed) {
        return NextResponse.json(
          { error: 'Rate limit exceeded' },
          {
            status: 429,
            headers: {
              'Retry-After': '60',
            },
          }
        );
      }
    }

    // Forward to backend
    const response = await forwardToBackend(
      proxyReq.service,
      proxyReq.endpoint,
      req,
      proxyReq.userId || 'anonymous'
    );

    // Check if this is a sensitive operation for audit logging
    const isSensitive = isSensitiveOperation(
      proxyReq.service,
      proxyReq.endpoint,
      req.method
    );

    // Audit log if needed
    if (config.auditLog && isSensitive) {
      await auditLog(
        proxyReq.userId || 'anonymous',
        proxyReq.service,
        proxyReq.endpoint,
        req.method,
        response.status,
        isSensitive
      );
    }

    // Sanitize response headers
    const sanitizedHeaders = sanitizeResponseHeaders(response.headers);

    // Create response with sanitized headers
    const newResponse = new NextResponse(response.body, {
      status: response.status,
      statusText: response.statusText,
      headers: sanitizedHeaders,
    });

    return newResponse;
  } catch (error) {
    console.error('Proxy error:', error);

    return NextResponse.json(
      {
        error: 'Internal server error',
        message: process.env.NODE_ENV === 'development' ? String(error) : undefined,
      },
      { status: 500 }
    );
  }
}

/**
 * Export handlers for HTTP methods
 */
export const GET = middleware;
export const POST = middleware;
export const PUT = middleware;
export const PATCH = middleware;
export const DELETE = middleware;
export const HEAD = middleware;

export const runtime = 'nodejs';
