# Security & Environment Configuration
# Copy this to .env.local and fill in your values

# Node Environment
NODE_ENV=production

# Allowed Origins (CORS)
ALLOWED_ORIGIN=https://victor-ia.com
ALLOWED_ORIGINS=https://victor-ia.com,https://www.victor-ia.com,http://localhost:3000

# Security Headers
ENABLE_CSP=true
ENABLE_HSTS=true
HSTS_MAX_AGE=31536000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_API_PER_HOUR=10000
RATE_LIMIT_AUTH_PER_15MIN=100
RATE_LIMIT_GENERAL_PER_MINUTE=100

# Audit Logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_SUSPICIOUS_ACTIVITY=true

# API Security
API_KEY_ENCRYPTION_KEY=your-secret-key-here
API_KEY_EXPIRY_DAYS=365

# Webhook Security
WEBHOOK_SIGNATURE_SECRET=your-webhook-secret-here
WEBHOOK_TIMEOUT_MS=30000

# Authentication
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Database (Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Logging & Monitoring
LOG_LEVEL=info
SENTRY_DSN=your-sentry-dsn-here
ENABLE_DEBUG_LOGGING=false

# Feature Flags
ENABLE_RATE_LIMITING=true
ENABLE_AUDIT_LOGGING=true
ENABLE_SECURITY_HEADERS=true
ENABLE_CORS_CHECK=true
ENABLE_INPUT_VALIDATION=true

# Session & Cookies
SESSION_SECRET=your-session-secret-here
COOKIE_SECURE=true
COOKIE_SAME_SITE=Strict
COOKIE_HTTP_ONLY=true

# Compliance
GDPR_ENABLED=true
CCPA_ENABLED=true
ENABLE_DATA_EXPORT=true
ENABLE_DATA_DELETION=true
RETENTION_DAYS=365