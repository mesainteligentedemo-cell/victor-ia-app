# ============================================================================
# VICTOR IA APP — .env.example (PLANTILLA PARA DESARROLLO)
# ============================================================================
#
# INSTRUCCIONES RÁPIDAS:
# 1. Copia este archivo a .env.local:   cp .env.example .env.local
# 2. Obtén las keys de cada plataforma (ver comentarios de dónde obtenerlas)
# 3. Reemplaza TODOS los valores XXX con los reales
# 4. NUNCA comitees .env.local a Git (ya está en .gitignore)
# 5. En producción: usa Vercel Secrets, AWS Secrets Manager, o Doppler
#
# ============================================================================

# ============================================================================
# 1. INTELIGENCIA ARTIFICIAL
# ============================================================================

# OpenRouter: proveedor unificado de IA (Claude, GPT-4, Llama, etc)
# Obtener en: https://openrouter.ai → API Keys
OPENROUTER_API_KEY=sk-or-v1-xxxxx

# Anthropic Claude: análisis y procesamiento avanzado
# Obtener en: https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ============================================================================
# 2. AUTENTICACIÓN — CLERK
# ============================================================================

# Publishable Key: se envía al navegador, identifica tu app en Clerk
# Obtener en: https://dashboard.clerk.com → Settings → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# Secret Key: PRIVADA, solo servidor, autentica requests a Clerk
# Obtener en: https://dashboard.clerk.com → Settings → API Keys
CLERK_SECRET_KEY=sk_test_xxxxx

# Webhook Secret: verifica que webhooks (user.created, etc) vengan de Clerk
# Obtener en: https://dashboard.clerk.com → Webhooks → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_xxxxx

# Rutas de autenticación
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ============================================================================
# 3. PAGOS — STRIPE
# ============================================================================

# Public Key: se envía al navegador para crear intentos de pago
# Obtener en: https://dashboard.stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Secret Key: PRIVADA, solo servidor, gestiona suscripciones y cargos
# Obtener en: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_xxxxx

# Webhook Secret: verifica que webhooks (charge.succeeded, etc) vengan de Stripe
# Obtener en: https://dashboard.stripe.com → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# IDs de productos (obtener desde Stripe → Products)
STRIPE_STARTER_PRICE_ID=price_xxxxx
STRIPE_PRO_PRICE_ID=price_xxxxx

# ============================================================================
# 4. VOZ IA — ELEVENLABS
# ============================================================================

# API Key: genera audio y gestiona agentes
# Obtener en: https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=sk_87d5...

# Voice ID: ID específico de la voz de Victor
ELEVENLABS_VOICE_ID=iDEmt5MnqUotdwCIVplo

# Agent ID: ID del agente publicado en cliente
# Obtener en: https://elevenlabs.io → Agents → Tu agente
ELEVENLABS_AGENT_ID=agent_xxxxx

# ============================================================================
# 5. BASE DE DATOS — SUPABASE
# ============================================================================

# Project URL: identifica tu proyecto Supabase
# Obtener en: https://app.supabase.com → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Anon Key: acceso desde navegador (REQUIERE Row Level Security)
# Obtener en: https://app.supabase.com → Settings → API → anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx

# Service Role Key: PRIVADA, acceso total en servidor (ignora RLS)
# Obtener en: https://app.supabase.com → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# Conexión TCP (si usas Prisma, Drizzle, etc)
# Obtener en: https://app.supabase.com → Settings → Database → Connection String
DATABASE_URL=postgresql://postgres:password@localhost:5432/victor_ia_db

# ============================================================================
# 6. GENERACIÓN DE CONTENIDO — HIGGSFIELD (Imagen/Video)
# ============================================================================

# API Key para generar imágenes y videos (opcional)
# Obtener en: https://higgsfield.com → API Keys
HIGGSFIELD_API_KEY=hf_xxxxx

# ============================================================================
# 7. GOOGLE SHEETS (ANALYTICS OPCIONAL)
# ============================================================================

# API Key: acceso a sheets desde backend
GOOGLE_SHEETS_API_KEY=xxxxx

# ID del spreadsheet (para tracking, analytics, etc)
GOOGLE_SPREADSHEET_ID=1rmoA...

# ============================================================================
# 8. SEGURIDAD — TOKENS Y CIFRADO
# ============================================================================

# JWT Secret: firma de JWTs en /api/auth/token
# Generar: openssl rand -base64 32
JWT_SECRET=

# Encryption Key: cifra datos sensibles en BD (AES-256-GCM)
# Generar: openssl rand -base64 32 (tomar primeros 16 caracteres)
ENCRYPTION_KEY=

# NextAuth Secret (si usas NextAuth)
NEXTAUTH_SECRET=

# Session Secret (sesiones customizadas)
SESSION_SECRET=

# ============================================================================
# 9. ENTORNO Y DEBUG
# ============================================================================

# development = logs verbosos, hot reload
# production = optimizado, logs críticos solo
NODE_ENV=development

# URL pública de la app (para cookies, redirects, etc)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Debug: true = logs detallados, false = producción
DEBUG=true

# Log Level: debug, info, warn, error
LOG_LEVEL=debug

# ============================================================================
# CHECKLIST ANTES DE DESPLEGAR
# ============================================================================
#
# ☐ Todos los valores XXX reemplazados con valores reales
# ☐ En desarrollo: NODE_ENV=development, DEBUG=true
# ☐ En producción: NODE_ENV=production, DEBUG=false
# ☐ Keys de test (pk_test_, sk_test_) en desarrollo
# ☐ Keys de live (pk_live_, sk_live_) en producción
# ☐ Row Level Security habilitado en Supabase
# ☐ Webhooks configurados en Clerk y Stripe
# ☐ .env.local está en .gitignore
# ☐ Nunca commitar archivos .env*
# ☐ En producción: usar Vercel Secrets Dashboard o AWS Secrets Manager
#
# ============================================================================

# ============================================================
# PHASE 2-4 ADDITIONS (Creative Studio / Settings / Finance)
# ============================================================
# Anthropic model used by studio text generators (presentation/proposal/email)
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# ElevenLabs TTS model for Voice Studio
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# Cloudinary (avatar upload in Settings) — unsigned preset
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
